# ====================================
# S.P.E.C. Valuation Engine - .gitignore
# ====================================

# ----- SECRETS (CRITICAL) -----
.env
.env.*
!.env.example
*.pem
*.key

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ----- Virtual Environments -----
venv/
ENV/
env/
.venv/

# ----- Data & Models -----
data/raw/
*.db
*.sqlite
*.sqlite3
*.pkl
*.pickle
*.parquet
*.csv
!data/.gitkeep
!reports/**/*.csv

# ----- IDE & OS -----
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
.agent/

# ----- Claude Code Config (Track agents and commands) -----
# Note: .claude/ is tracked for agent definitions

# ----- Generated Assets -----
assets/*.png
assets/*.jpg
assets/*.jpeg

# ----- Streamlit -----
.streamlit/secrets.toml

# ----- Logs -----
*.log
logs/

# ----- MLflow (Experiment Tracking) -----
mlruns/
mlartifacts/

# ----- Tests (Not needed in production) -----
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
!tests/
!tests/**/*.py

# ----- Vector Databases & Embeddings -----
data/vector_db/
*.chroma/
chroma_db/

# ----- Jupyter Notebooks -----
.ipynb_checkpoints/
*.ipynb

# ----- Large Model Files -----
*.h5
*.hdf5
*.onnx
*.pt
*.pth
*.safetensors

# ----- Local Smoke Artifacts -----
models/*smoke*
reports/**/*smoke*
reports/validation/smoke_inputs/

# ----- Local Generated Experiment Artifacts -----
# Keep stable baseline artifacts (e.g., model_v1.joblib, metrics_v1.json) tracked.
# Ignore timestamped/ad-hoc candidate outputs.
models/model_v1_*.joblib
models/metrics_v1_*.json
reports/model/evaluation_predictions_v1_*.csv
reports/model/segment_scorecard_v1_*.csv
reports/model/temporal_scorecard_v1_*.csv
reports/model/shap_summary_v1_*.png
reports/model/shap_waterfall_v1_*.png

# ----- Local Demo Runtime Snapshots -----
reports/demo/stakeholder_demo_snapshot_latest.json
reports/demo/stakeholder_demo_snapshot_latest.md
reports/validation/demo_smoke_readiness_latest.json
reports/validation/demo_smoke_readiness_latest.md

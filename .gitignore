# ====================================
# S.P.E.C. Valuation Engine - .gitignore
# ====================================

# ----- SECRETS (CRITICAL) -----
.env
.env.*
!.env.example
*.pem
*.key

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
!web/src/lib/
!web/src/lib/**/*.ts
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ----- Virtual Environments -----
venv/
ENV/
env/
.venv/

# ----- Data & Models -----
data/raw/
*.db
*.sqlite
*.sqlite3
*.pkl
*.pickle
*.parquet
*.csv
!data/.gitkeep
!reports/**/*.csv

# ----- IDE & OS -----
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
.agent/

# ----- Node / Frontend -----
node_modules/
.next/
.turbo/
coverage/
.eslintcache
web/.next/
web/.turbo/
web/coverage/
web/.eslintcache
*.tsbuildinfo
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel/
web/.vercel/

# ----- Claude Code Config (Track agents and commands) -----
# Note: .claude/ is tracked for agent definitions

# ----- Generated Assets -----
assets/*.png
assets/*.jpg
assets/*.jpeg

# ----- Streamlit -----
.streamlit/secrets.toml

# ----- Logs -----
*.log
logs/

# ----- MLflow (Experiment Tracking) -----
mlruns/
mlartifacts/

# ----- Tests (Not needed in production) -----
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
web/test-results/
!tests/
!tests/**/*.py

# ----- Vector Databases & Embeddings -----
data/vector_db/
*.chroma/
chroma_db/

# ----- Jupyter Notebooks -----
.ipynb_checkpoints/
*.ipynb

# ----- Large Model Files -----
*.h5
*.hdf5
*.onnx
*.pt
*.pth
*.safetensors

# ----- Local Smoke Artifacts -----
models/*smoke*
reports/**/*smoke*
reports/validation/smoke_inputs/

# ----- Local Generated Experiment Artifacts -----
# Keep stable baseline artifacts (e.g., model_v1.joblib, metrics_v1.json) tracked.
# Ignore timestamped/ad-hoc candidate outputs.
models/model_v1_*.joblib
models/metrics_v1_*.json
reports/model/evaluation_predictions_v1_*.csv
reports/model/segment_scorecard_v1_*.csv
reports/model/temporal_scorecard_v1_*.csv
reports/model/shap_summary_v1_*.png
reports/model/shap_waterfall_v1_*.png

# ----- Local Demo Runtime Snapshots -----
reports/demo/stakeholder_demo_snapshot_latest.json
reports/demo/stakeholder_demo_snapshot_latest.md
reports/validation/demo_smoke_readiness_latest.json
reports/validation/demo_smoke_readiness_latest.md

# ----- Local Governed Platform Runtime Artifacts -----
# Stable curated evidence can still be tracked with `git add -f` when needed.
reports/valuations/
reports/experiments/exp_20*.json
reports/experiments/runs/exp_20*/
reports/governance/proposals/proposal_20*/

# ----- Local Arena/ETL Run Outputs (timestamped) -----
reports/arena/run_card_*.md
reports/arena/proposal_*.json
reports/arena/proposal_*.md
reports/arena/comparison_*.csv
reports/data/canonical_mapping_*.json
reports/data/etl_run_20*.csv
reports/data/etl_run_20*.md
reports/data/onboarding_profile_*.json
reports/data/onboarding_profile_*.md
reports/data/onboarding_report_*.md
reports/validation/*_production_readiness_20*.json
reports/validation/*_production_readiness_20*.md

# S.P.E.C. NYC Environment Variables

# Database
DATABASE_URL=postgresql://spec:spec_password@localhost:5433/spec_nyc
DATABASE_PATH=data/processed/spec_nyc.sqlite3
SOCRATA_APP_TOKEN=

# OpenAI (for AI memos in V4)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
AI_AUDIT_BACKEND=postgres
AI_DAILY_COST_LIMIT_USD=25.0
AI_REQUEST_COST_LIMIT_USD=2.0
AI_MAX_OUTPUT_TOKENS=1200

# MLflow (optional)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Application
DEBUG=false
LOG_LEVEL=INFO

# Web Branding / Access
# default: neutral branding
# azuli: azuli branding profile
APP_BRAND=default
# Comma-separated hostnames that should request azuli branding
AZULI_BRAND_HOSTS=
# When true, azuli branding requires a signed access token
BRAND_REQUIRE_TOKEN_FOR_AZULI=true
# Required if BRAND_REQUIRE_TOKEN_FOR_AZULI=true
BRAND_ACCESS_SECRET=replace_with_long_random_secret
